<?xml version="1.0" encoding="utf-8"?>
<!-- Fondo del widget: forma redondeada con gradiente oscuro semitransparente -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#DD37353E"
        android:endColor="#CC44444E"
        android:angle="135" />
    <corners android:radius="16dp" />
    <stroke
        android:width="1dp"
        android:color="#55BFA28C" />
</shape>
