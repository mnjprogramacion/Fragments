<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Línea base más clara y gruesa con un difuminado en los extremos -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:centerColor="@color/primary_container"
                android:endColor="#00000000"
                android:angle="0" />
            <size android:height="4dp" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    
    <!-- Línea interior más oscura y fina, también difuminada, creando efecto de profundidad (relieve sutil) -->
    <item
        android:top="1dp"
        android:bottom="1dp"
        android:left="16dp"
        android:right="16dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#00000000"
                android:centerColor="@color/primary"
                android:endColor="#00000000"
                android:angle="0" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
